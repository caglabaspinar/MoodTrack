<Window x:Class="MoodTrack.DailyEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MoodTrack"
        mc:Ignorable="d"
        Title="Günlük Giriş"
        Height="720"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5FA">

    <Grid Margin="20">
        <Border Background="#FFEAF4"
                CornerRadius="28"
                Padding="24"
                BorderBrush="#F5A9C2"
                BorderThickness="2">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Günlük Giriş"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#C84F7B"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Bugünün hislerini yumuşakça kaydet"
                               FontSize="14"
                               Foreground="#A85D7A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,22"/>

                    <TextBlock Text="Tarih"
                               FontWeight="SemiBold"
                               Foreground="#A64D79"
                               Margin="0,0,0,6"/>

                    <DatePicker x:Name="dpDate"
                                Height="38"
                                Margin="0,0,0,18"
                                SelectedDateChanged="dpDate_SelectedDateChanged"/>

                    <Border Background="#FFF8FC"
                            CornerRadius="22"
                            Padding="18"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Hayat Puanı"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#C84F7B"
                                       Margin="0,0,0,12"/>

                            <ComboBox x:Name="cbLifeScore"
                                      Height="38"
                                      Margin="0,0,0,8">
                                <ComboBoxItem Content="1 - çok kötü / very bad"/>
                                <ComboBoxItem Content="2 - kötü / bad"/>
                                <ComboBoxItem Content="3 - orta / neutral"/>
                                <ComboBoxItem Content="4 - iyi / good"/>
                                <ComboBoxItem Content="5 - çok iyi / very good"/>
                            </ComboBox>

                            <TextBlock Text="Hayat Yorumu"
                                       FontWeight="SemiBold"
                                       Foreground="#A64D79"
                                       Margin="0,8,0,6"/>

                            <TextBox x:Name="txtLifeComment"
                                     Height="110"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8FC"
                            CornerRadius="22"
                            Padding="18"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="İlişki Puanı"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#C84F7B"
                                       Margin="0,0,0,12"/>

                            <ComboBox x:Name="cbRelationshipScore"
                                      Height="38"
                                      Margin="0,0,0,8">
                                <ComboBoxItem Content="1 - çok kötü / very bad"/>
                                <ComboBoxItem Content="2 - kötü / bad"/>
                                <ComboBoxItem Content="3 - orta / neutral"/>
                                <ComboBoxItem Content="4 - iyi / good"/>
                                <ComboBoxItem Content="5 - çok iyi / very good"/>
                            </ComboBox>

                            <TextBlock Text="İlişki Yorumu"
                                       FontWeight="SemiBold"
                                       Foreground="#A64D79"
                                       Margin="0,8,0,6"/>

                            <TextBox x:Name="txtRelationshipComment"
                                     Height="110"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>

                    <WrapPanel HorizontalAlignment="Center" Margin="0,8,0,0">
                        <Button x:Name="btnSaveDailyEntry"
                                Content="Kaydet"
                                Width="150"
                                Height="44"
                                Margin="0,0,12,0"
                                FontWeight="Bold"
                                Background="#E989AF"
                                Foreground="White"
                                BorderBrush="#E989AF"
                                Click="BtnSaveDailyEntry_Click"/>

                        <Button x:Name="btnClose"
                                Content="Kapat"
                                Width="150"
                                Height="44"
                                FontWeight="Bold"
                                Background="#FFD7E8"
                                Foreground="#A64D79"
                                BorderBrush="#F2A8C5"
                                Click="BtnClose_Click"/>
                    </WrapPanel>

                    <TextBlock x:Name="txtStatus"
                               Text=""
                               Foreground="#A64D79"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>