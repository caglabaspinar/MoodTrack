<Page x:Class="MoodTrack.BossPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FFF5FA">

    <Grid Margin="20">
        <Border Background="#FFEAF4"
                CornerRadius="28"
                Padding="24"
                BorderBrush="#F5A9C2"
                BorderThickness="2">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- HEADER + GERİ -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="←"
                                Width="36"
                                Height="36"
                                Click="BtnBack_Click"
                                Background="#E989AF"
                                Foreground="White"
                                BorderBrush="#E989AF"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="👑"
                                       FontSize="36"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Boss"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#C84F7B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="txtDate"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#A85D7A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Günlük hedefler"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#A64D79"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="txtGoals"
                             Height="140"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"
                             Background="#FFF8FC"
                             BorderBrush="#F2A8C5"
                             BorderThickness="2"
                             Margin="0,0,0,18"/>

                    <TextBlock Text="Bugün öğrendiğim / dikkat edeceğim şeyler"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#A64D79"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="txtNotes"
                             Height="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"
                             Background="#FFF8FC"
                             BorderBrush="#F2A8C5"
                             BorderThickness="2"
                             Margin="0,0,0,18"/>

                    <TextBlock Text="Genel değerlendirme"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#A64D79"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="txtReview"
                             Height="160"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"
                             Background="#FFF8FC"
                             BorderBrush="#F2A8C5"
                             BorderThickness="2"
                             Margin="0,0,0,24"/>

                    <Button Content="Kaydet"
                            Height="44"
                            Click="BtnSave_Click"
                            Background="#E989AF"
                            Foreground="White"
                            BorderBrush="#E989AF"
                            Margin="0,0,0,10"/>

                    <TextBlock x:Name="txtSaveStatus"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#C84F7B"
                               HorizontalAlignment="Center"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>