<Page x:Class="MoodTrack.GoalsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FFF5FA">

    <Grid Margin="20">
        <Border Background="#FFEAF4"
                CornerRadius="28"
                Padding="24"
                BorderBrush="#F5A9C2"
                BorderThickness="2">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- HEADER + GERİ -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="←"
                                Width="36"
                                Height="36"
                                Click="GoBack_Click"
                                Background="#E989AF"
                                Foreground="White"
                                BorderBrush="#E989AF"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="☑"
                                       FontSize="36"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Daily Goals"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#C84F7B"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="txtDate"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#A85D7A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Günlük hedef ekle"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#A64D79"
                               Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtNewGoal"
                                 Grid.Column="0"
                                 Height="50"
                                 FontSize="16"
                                 Padding="10"
                                 Background="#FFF8FC"
                                 BorderBrush="#F2A8C5"
                                 BorderThickness="2"/>

                        <Button Grid.Column="2"
                                Content="Ekle"
                                Height="40"
                                Click="BtnAddGoal_Click"
                                Background="#E989AF"
                                Foreground="White"
                                BorderBrush="#E989AF"/>
                    </Grid>

                    <Border Background="#FFF8FC"
                            BorderBrush="#F2A8C5"
                            BorderThickness="2"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,22">
                        <StackPanel x:Name="goalsPanel"/>
                    </Border>

                    <Button Content="Kaydet"
                            Height="44"
                            Click="BtnSave_Click"
                            Background="#E989AF"
                            Foreground="White"
                            BorderBrush="#E989AF"
                            Margin="0,0,0,10"/>

                    <TextBlock x:Name="txtSaveStatus"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#C84F7B"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>