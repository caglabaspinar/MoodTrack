<Window x:Class="MoodTrack.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MoodTrack"
        mc:Ignorable="d"
        Title="MoodTrack"
        Height="760"
        Width="520"
        MinHeight="650"
        MinWidth="480"
        MaxHeight="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#FFF5FA">

    <Grid Margin="20">

        <Border x:Name="LoginPanel"
                Background="#FFEAF4"
                CornerRadius="28"
                Padding="28"
                BorderBrush="#F5A9C2"
                BorderThickness="2">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="MoodTrack"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#C84F7B"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,8"/>

                <TextBlock Text="Benle duygularını takip et"
                           FontSize="14"
                           Foreground="#A85D7A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <Border Background="#FFF8FC"
                        CornerRadius="22"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="PIN Girişi"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#C84F7B"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="4 haneli PIN"
                                   FontWeight="SemiBold"
                                   Foreground="#A64D79"
                                   Margin="0,0,0,6"/>

                        <PasswordBox x:Name="txtPin"
                                     Height="42"
                                     FontSize="18"
                                     MaxLength="4"
                                     Margin="0,0,0,18"
                                     VerticalContentAlignment="Center"/>

                        <Button x:Name="btnLogin"
                                Content="Giriş Yap"
                                Height="44"
                                FontWeight="Bold"
                                Background="#E989AF"
                                Foreground="White"
                                BorderBrush="#E989AF"
                                Click="BtnLogin_Click"/>

                        <TextBlock x:Name="txtLoginStatus"
                                   Text=""
                                   Foreground="#C94A6A"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Margin="0,14,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <Border x:Name="HomePanel"
                Visibility="Collapsed"
                Background="#FFEAF4"
                CornerRadius="28"
                Padding="28"
                BorderBrush="#F5A9C2"
                BorderThickness="2">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock x:Name="txtWelcome"
                               Text="Hoş geldin"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#C84F7B"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,10"/>

                    <TextBlock Text="Bugün hangi sayfaya gitmek istersin?"
                               FontSize="14"
                               Foreground="#A85D7A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,26"/>

                    <Button x:Name="btnDailyEntry"
                            Height="120"
                            Margin="0,0,0,18"
                            Background="#FFD7E8"
                            BorderBrush="#F2A8C5"
                            BorderThickness="2"
                            Click="BtnDailyEntry_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📝"
                                       FontSize="34"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Daily Entry"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#A64D79"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnGoals"
                            Height="120"
                            Margin="0,0,0,18"
                            Background="#FFE0EC"
                            BorderBrush="#F2A8C5"
                            BorderThickness="2"
                            Click="BtnGoals_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="☑"
                                       FontSize="34"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Goals"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#A64D79"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnCalendar"
                            Height="120"
                            Margin="0,0,0,18"
                            Background="#FFDDEE"
                            BorderBrush="#F2A8C5"
                            BorderThickness="2"
                            Click="BtnCalendar_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📅"
                                       FontSize="34"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Calendar"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#A64D79"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnBoss"
                            Height="120"
                            Margin="0,0,0,18"
                            Background="#FFE3EF"
                            BorderBrush="#F2A8C5"
                            BorderThickness="2"
                            Click="BtnBoss_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="👑"
                                       FontSize="34"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Boss"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#A64D79"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnReports"
                            Height="120"
                            Margin="0,0,0,24"
                            Background="#FFF0F7"
                            BorderBrush="#F2A8C5"
                            BorderThickness="2"
                            Click="BtnReports_Click">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📊"
                                       FontSize="34"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Reports"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#A64D79"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnLogout"
                            Content="Çıkış Yap"
                            Height="46"
                            FontWeight="Bold"
                            Background="#E08AB0"
                            Foreground="White"
                            BorderBrush="#E08AB0"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>