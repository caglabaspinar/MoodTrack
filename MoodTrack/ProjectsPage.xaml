<Page x:Class="MoodTrack.ProjectsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Projects"
      Background="#F6F0FF">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#E6D9FF"
                CornerRadius="16"
                Padding="16"
                Margin="0,0,0,12"
                BorderBrush="#C8A8F0"
                BorderThickness="1.5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="←"
                        Width="36"
                        Height="36"
                        Click="BtnBack_Click"
                        Background="#C9A7FF"
                        Foreground="White"
                        BorderBrush="#C9A7FF"
                        FontWeight="Bold"/>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Projelerim"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#5B3FA0"/>
                    <TextBlock Text="Uzun süreli projelerini burada takip edebilirsin."
                               Margin="0,6,0,0"
                               Foreground="#7A5BBE"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="16"
                Padding="14"
                BorderBrush="#D6BFF5"
                BorderThickness="1.5">
            <StackPanel>
                <TextBlock Text="Yeni Proje"
                           FontWeight="SemiBold"
                           Foreground="#5B3FA0"
                           Margin="0,0,0,8"/>

                <TextBox x:Name="txtProjectName"
                         Height="38"
                         Padding="10,6"
                         FontSize="14"
                         Background="#FCFAFF"
                         BorderBrush="#C8A8F0"
                         BorderThickness="1.5"
                         Margin="0,0,0,10"/>

                <Button Content="Proje Ekle"
                        Height="40"
                        Click="AddProject_Click"
                        Background="#C9A7FF"
                        Foreground="White"
                        BorderBrush="#C9A7FF"
                        BorderThickness="2"
                        FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Projelerim"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#6B3FA0"
                           Margin="0,0,0,12"/>

                <ItemsControl x:Name="lstProjects">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Click="Project_Click"
                                    Tag="{Binding Id}"
                                    Margin="0,0,0,12"
                                    Padding="14"
                                    Background="#F0E6FF"
                                    BorderBrush="#C8A8F0"
                                    BorderThickness="2"
                                    HorizontalContentAlignment="Stretch">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#5B3FA0"
                                           TextWrapping="Wrap"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>