<Window x:Class="MoodTrack.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="İlk Kurulum"
        Height="760"
        Width="520"
        MinHeight="760"
        MinWidth="520"
        MaxHeight="760"
        MaxWidth="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5FA">

    <Grid Margin="20">
        <Border Background="#FFEAF4"
                CornerRadius="28"
                Padding="28"
                BorderBrush="#F5A9C2"
                BorderThickness="2">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="İlk Kurulum"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#C84F7B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="MoodTrack kullanmaya başlamadan önce bilgilerini gir."
                           FontSize="14"
                           Foreground="#A85D7A"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,28"/>

                <Border Background="#FFF8FC"
                        CornerRadius="22"
                        Padding="22">
                    <StackPanel>

                        <TextBlock Text="Ad Soyad"
                                   FontWeight="SemiBold"
                                   Foreground="#A64D79"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtName"
                                 Height="40"
                                 Margin="0,0,0,14"
                                 Padding="10,6"
                                 Background="White"
                                 BorderBrush="#F2A8C5"
                                 BorderThickness="2"/>

                        <TextBlock Text="Email"
                                   FontWeight="SemiBold"
                                   Foreground="#A64D79"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="txtEmail"
                                 Height="40"
                                 Margin="0,0,0,14"
                                 Padding="10,6"
                                 Background="White"
                                 BorderBrush="#F2A8C5"
                                 BorderThickness="2"/>

                        <TextBlock Text="PIN (4 haneli)"
                                   FontWeight="SemiBold"
                                   Foreground="#A64D79"
                                   Margin="0,0,0,6"/>
                        <PasswordBox x:Name="txtPin"
                                     Height="40"
                                     Margin="0,0,0,22"
                                     Padding="10,6"
                                     BorderBrush="#F2A8C5"
                                     BorderThickness="2"/>

                        <Button Content="Kaydet"
                                Height="42"
                                Background="#E989AF"
                                Foreground="White"
                                BorderBrush="#E989AF"
                                FontWeight="Bold"
                                Click="BtnSave_Click"/>

                        <TextBlock x:Name="txtStatus"
                                   Margin="0,12,0,0"
                                   Foreground="#C94A6A"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</Window>