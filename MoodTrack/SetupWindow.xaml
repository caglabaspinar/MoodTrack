<Window x:Class="MoodTrack.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="İlk Kurulum"
        Height="400"
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF5FA">

    <Grid Margin="20">
        <Border Background="#FFEAF4"
                CornerRadius="20"
                Padding="20"
                BorderBrush="#F5A9C2"
                BorderThickness="2">

            <StackPanel>

                <TextBlock Text="İlk Kurulum"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#C84F7B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Ad Soyad"/>
                <TextBox x:Name="txtName" Margin="0,5,0,10"/>

                <TextBlock Text="Email"/>
                <TextBox x:Name="txtEmail" Margin="0,5,0,10"/>

                <TextBlock Text="PIN (4 haneli)"/>
                <PasswordBox x:Name="txtPin" Margin="0,5,0,20"/>

                <Button Content="Kaydet"
                        Height="35"
                        Background="#E989AF"
                        Foreground="White"
                        Click="BtnSave_Click"/>

                <TextBlock x:Name="txtStatus"
                           Margin="0,10,0,0"
                           Foreground="Red"
                           TextAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>