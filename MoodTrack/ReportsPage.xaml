<Page x:Class="MoodTrack.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Raporlar"
      Background="#FFF5FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ÜST BAŞLIK -->
        <Border Grid.Row="0"
                Background="#FFEAF4"
                CornerRadius="24"
                Padding="18"
                BorderBrush="#F5A9C2"
                BorderThickness="2"
                Margin="0,0,0,12">

            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="←"
                            Width="36"
                            Height="36"
                            Click="BtnBack_Click"
                            Background="#E989AF"
                            Foreground="White"
                            BorderBrush="#E989AF"
                            FontWeight="Bold"/>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Raporlar"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#C84F7B"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Haftalık ve aylık özetlerini burada görebilirsin"
                                   FontSize="14"
                                   Foreground="#A85D7A"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- HAFTALIK -->
        <Border Grid.Row="1"
                Background="#FFEAF4"
                CornerRadius="24"
                Padding="18"
                BorderBrush="#F5A9C2"
                BorderThickness="2"
                Margin="0,0,0,12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Haftalık Rapor"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#C84F7B"
                           Margin="0,0,0,10"/>

                <TextBox x:Name="txtWeeklyReport"
                         Grid.Row="1"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Background="White"
                         BorderBrush="#F5A9C2"
                         Padding="12"
                         FontSize="14"/>
            </Grid>
        </Border>

        <!-- AYLIK -->
        <Border Grid.Row="2"
                Background="#FFEAF4"
                CornerRadius="24"
                Padding="18"
                BorderBrush="#F5A9C2"
                BorderThickness="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Aylık Rapor"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#C84F7B"
                           Margin="0,0,0,10"/>

                <TextBox x:Name="txtMonthlyReport"
                         Grid.Row="1"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Background="White"
                         BorderBrush="#F5A9C2"
                         Padding="12"
                         FontSize="14"/>
            </Grid>
        </Border>
    </Grid>
</Page>