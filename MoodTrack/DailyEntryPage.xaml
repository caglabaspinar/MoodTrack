<Page x:Class="MoodTrack.DailyEntryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FFF5FA">

    <Grid Margin="20">
        <Border Background="#FFEAF4"
                CornerRadius="28"
                Padding="24"
                BorderBrush="#F5A9C2"
                BorderThickness="2">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- HEADER + GERİ -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="←"
                                Width="36"
                                Height="36"
                                Click="BtnBack_Click"
                                Background="#E989AF"
                                Foreground="White"
                                BorderBrush="#E989AF"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Günlük Giriş"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="#C84F7B"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Bugünün hislerini kaydet"
                                       FontSize="13"
                                       Foreground="#A85D7A"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,10"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Tarih"
                               FontWeight="SemiBold"
                               Foreground="#A64D79"/>

                    <DatePicker x:Name="dpDate"
                                Height="38"
                                Margin="0,6,0,18"
                                SelectedDateChanged="dpDate_SelectedDateChanged"/>

                    <!-- HAYAT -->
                    <Border Background="#FFF8FC"
                            CornerRadius="22"
                            Padding="18"
                            Margin="0,0,0,16">
                        <StackPanel>

                            <TextBlock Text="Hayat Puanı"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#C84F7B"/>

                            <ComboBox x:Name="cbLifeScore" Margin="0,8,0,8">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5"/>
                            </ComboBox>

                            <TextBox x:Name="txtLifeComment"
                                     Height="100"
                                     AcceptsReturn="True"/>
                        </StackPanel>
                    </Border>

                    <!-- İLİŞKİ -->
                    <Border Background="#FFF8FC"
                            CornerRadius="22"
                            Padding="18"
                            Margin="0,0,0,16">
                        <StackPanel>

                            <TextBlock Text="İlişki Puanı"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#C84F7B"/>

                            <ComboBox x:Name="cbRelationshipScore" Margin="0,8,0,8">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5"/>
                            </ComboBox>

                            <TextBox x:Name="txtRelationshipComment"
                                     Height="100"
                                     AcceptsReturn="True"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Kaydet"
                            Height="44"
                            Click="BtnSaveDailyEntry_Click"
                            Background="#E989AF"
                            Foreground="White"
                            Margin="0,0,0,10"/>

                    <TextBlock x:Name="txtStatus"
                               HorizontalAlignment="Center"
                               Foreground="#A64D79"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>